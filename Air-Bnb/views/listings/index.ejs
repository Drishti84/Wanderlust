<% layout("/layouts/boilerplate") %>

<!-- Filter Bar (full-width, outside container) -->
<div class="filter-bar">
  <div class="filter-bar-inner">
    <a href="/listings" class="filter-pill <%= !activeCategory ? 'active' : '' %>">
      <i class="fa-solid fa-border-all"></i><span>All</span>
    </a>
    <a href="/listings?category=trending" class="filter-pill <%= activeCategory === 'trending' ? 'active' : '' %>">
      <i class="fa-solid fa-fire"></i><span>Trending</span>
    </a>
    <a href="/listings?category=rooms" class="filter-pill <%= activeCategory === 'rooms' ? 'active' : '' %>">
      <i class="fa-solid fa-bed"></i><span>Rooms</span>
    </a>
    <a href="/listings?category=cities" class="filter-pill <%= activeCategory === 'cities' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain-city"></i><span>Iconic Cities</span>
    </a>
    <a href="/listings?category=mountains" class="filter-pill <%= activeCategory === 'mountains' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain"></i><span>Mountains</span>
    </a>
    <a href="/listings?category=castles" class="filter-pill <%= activeCategory === 'castles' ? 'active' : '' %>">
      <i class="fa-brands fa-fort-awesome"></i><span>Castles</span>
    </a>
    <a href="/listings?category=pools" class="filter-pill <%= activeCategory === 'pools' ? 'active' : '' %>">
      <i class="fa-solid fa-person-swimming"></i><span>Amazing Pools</span>
    </a>
    <a href="/listings?category=camping" class="filter-pill <%= activeCategory === 'camping' ? 'active' : '' %>">
      <i class="fa-solid fa-campground"></i><span>Camping</span>
    </a>
    <a href="/listings?category=farms" class="filter-pill <%= activeCategory === 'farms' ? 'active' : '' %>">
      <i class="fa-solid fa-tractor"></i><span>Farms</span>
    </a>
    <a href="/listings?category=arctic" class="filter-pill <%= activeCategory === 'arctic' ? 'active' : '' %>">
      <i class="fa-solid fa-snowflake"></i><span>Arctic</span>
    </a>
    <a href="/listings?category=domes" class="filter-pill <%= activeCategory === 'domes' ? 'active' : '' %>">
      <i class="fa-solid fa-landmark-dome"></i><span>Domes</span>
    </a>
    <a href="/listings?category=boating" class="filter-pill <%= activeCategory === 'boating' ? 'active' : '' %>">
      <i class="fa-solid fa-sailboat"></i><span>Boating</span>
    </a>

    <div class="tax-toggle-wrapper">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" role="switch" id="taxSwitch">
        <label class="form-check-label" for="taxSwitch">Show total with taxes</label>
      </div>
    </div>
  </div>
</div>

<!-- Listings Grid -->
<div class="listings-section">
  <% if (allListings.length === 0) { %>
    <div class="no-listings">
      <i class="fa-solid fa-magnifying-glass"></i>
      <p>No listings found in this category.</p>
      <a href="/listings" class="btn-coral">Browse all listings</a>
    </div>
  <% } else { %>
  <div class="listings-grid">
    <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>" class="listing-card">
        <img
          src="<%= listing.image.url %>"
          class="listing-card-img"
          alt="<%= listing.title %>"
          loading="lazy"
        >
        <div class="listing-card-body">
          <div class="listing-card-row">
            <div class="listing-card-title"><%= listing.title %></div>
            <div class="listing-card-rating">&#9733; New</div>
          </div>
          <div class="listing-card-location">
            <i class="fa-solid fa-location-dot me-1"></i>
            <%= listing.location %>, <%= listing.country %>
          </div>
          <div class="listing-card-price">
            &#8377;<%= listing.price.toLocaleString('en-IN') %>
            <span class="per-night">/ night</span>
          </div>
          <div class="tax-info">&#8377;<%= Math.round(listing.price * 1.18).toLocaleString('en-IN') %> total with taxes</div>
        </div>
      </a>
    <% } %>
  </div>
  <% } %>
</div>
