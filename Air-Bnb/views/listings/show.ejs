<% layout("/layouts/boilerplate") %>

<div class="show-container">
  <div class="show-layout">

    <!-- LEFT: Listing details -->
    <div class="show-left">
      <img src="<%= listing.image.url %>" class="show-hero" alt="<%= listing.title %>">

      <h1 class="show-title"><%= listing.title %></h1>
      <div class="show-owner">
        <div class="owner-avatar"><%= listing.owner.username.charAt(0).toUpperCase() %></div>
        <span>Hosted by <span class="owner-name">@<%= listing.owner.username %></span></span>
      </div>

      <hr class="show-divider">
      <p class="show-description"><%= listing.description %></p>

      <div class="show-meta">
        <div class="show-meta-item">
          <i class="fa-solid fa-location-dot"></i>
          <%= listing.location %>
        </div>
        <div class="show-meta-item">
          <i class="fa-solid fa-earth-americas"></i>
          <%= listing.country %>
        </div>
      </div>

      <div class="show-price">
        &#8377;<%= listing.price.toLocaleString('en-IN') %>
        <small>/ night</small>
      </div>

      <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="show-actions">
          <a href="/listings/<%= listing._id %>/edit" class="btn-ghost">
            <i class="fa-solid fa-pen-to-square"></i> Edit
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirmDelete()">
            <button type="submit" class="btn-danger-ghost">
              <i class="fa-solid fa-trash"></i> Delete
            </button>
          </form>
        </div>
      <% } %>
  </div>

  <!-- RIGHT: Booking card + Review form -->
  <div class="show-right">
    <div class="booking-card">
      <div class="booking-card-price">
        &#8377;<%= listing.price.toLocaleString('en-IN') %>
        <small>/ night</small>
      </div>

      <% if(currUser) { %>
        <form id="bookingForm" action="/listings/<%= listing._id %>/bookings" method="POST">
          <div class="booking-date-row">
            <div class="booking-date-field">
              <label class="booking-date-label">CHECK-IN</label>
              <input type="date" name="checkIn" id="checkIn" class="booking-date-input" required>
            </div>
            <div class="booking-date-divider"></div>
            <div class="booking-date-field">
              <label class="booking-date-label">CHECK-OUT</label>
              <input type="date" name="checkOut" id="checkOut" class="booking-date-input" required>
            </div>
          </div>

          <div class="booking-guests-row">
            <label class="booking-date-label">GUESTS</label>
            <select name="guests" class="booking-guests-select">
              <% for(let i = 1; i <= 8; i++) { %>
                <option value="<%= i %>"><%= i %> guest<%= i > 1 ? 's' : '' %></option>
              <% } %>
            </select>
          </div>

          <div id="bookingConflict" class="booking-conflict" style="display:none;">
            <i class="fa-solid fa-circle-exclamation me-1"></i>
            <span id="conflictMsg">Those dates are not available.</span>
          </div>

          <div id="priceSummary" class="booking-price-summary" style="display:none;">
            <div class="price-summary-row">
              <span id="nightsLabel">0 nights</span>
              <span id="nightsTotal">₹0</span>
            </div>
            <div class="price-summary-row price-summary-total">
              <span>Total</span>
              <span id="grandTotal">₹0</span>
            </div>
          </div>

          <button type="submit" id="reserveBtn" class="btn-coral w-full" disabled>Select dates to reserve</button>
        </form>

        <% if(bookedRanges.length > 0) { %>
        <div class="booked-dates-section">
          <p class="booked-dates-heading"><i class="fa-solid fa-ban me-1"></i>Unavailable dates</p>
          <% for(let r of bookedRanges) { %>
            <div class="booked-date-range">
              <%= new Date(r.checkIn).toLocaleDateString('en-IN', {day:'numeric', month:'short'}) %>
              &ndash;
              <%= new Date(r.checkOut).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
            </div>
          <% } %>
        </div>
        <% } %>

      <% } else { %>
        <div class="booking-login-prompt">
          <i class="fa-solid fa-lock mb-2" style="font-size:1.5rem;color:var(--text-secondary);display:block;text-align:center;"></i>
          <p>Log in to reserve this listing</p>
          <a href="/login" class="btn-coral w-full" style="text-align:center;">Log in to reserve</a>
        </div>
      <% } %>

      <div class="booking-divider"></div>

      <% if(currUser) { %>
        <h5 class="review-form-title">Leave a Review</h5>
        <form class="needs-validation" action="/listings/<%= listing.id %>/reviews" method="POST" novalidate>

          <div class="mb-3">
            <label class="form-label">Your Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" rows="3" class="form-control" required placeholder="Share your experience..."></textarea>
            <div class="invalid-feedback">Please write a comment before submitting.</div>
          </div>

          <button type="submit" class="btn-coral w-full">Submit Review</button>
        </form>
      <% } else { %>
        <p style="color: var(--text-secondary); font-size: 0.88rem; text-align: center;">
          <a href="/login" style="color: var(--coral);">Log in</a> to leave a review.
        </p>
      <% } %>
    </div>
  </div>

</div>

<!-- Map Section -->
<div class="show-map-section">
  <h3 class="show-map-heading">
    <i class="fa-solid fa-map-location-dot me-2"></i>Where you'll be
  </h3>
  <p class="show-map-location"><%= listing.location %>, <%= listing.country %></p>
  <% if (listing.coordinates && listing.coordinates.lat) { %>
  <%
    var _lat  = listing.coordinates.lat;
    var _lng  = listing.coordinates.lng;
    var _d    = 0.15;
    var _bbox = (_lng - _d) + ',' + (_lat - _d) + ',' + (_lng + _d) + ',' + (_lat + _d);
  %>
  <iframe
    class="listing-map-iframe"
    src="https://www.openstreetmap.org/export/embed.html?bbox=<%= _bbox %>&layer=mapnik&marker=<%= _lat %>,<%= _lng %>"
    allowfullscreen
    loading="lazy"
    title="Map of <%= listing.location %>"
  ></iframe>
  <% } %>
  <a
    href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(listing.location + ', ' + listing.country) %>"
    target="_blank"
    rel="noopener"
    class="btn-ghost show-map-directions"
  >
    <i class="fa-solid fa-diamond-turn-right me-1"></i> Get Directions
  </a>
</div>

<script>
(function() {
  var cin  = document.getElementById('checkIn');
  var cout = document.getElementById('checkOut');
  if (!cin) return;

  var pricePerNight = <%= listing.price %>;
  var bookedRanges  = <%- JSON.stringify(bookedRanges.map(r => ({ s: new Date(r.checkIn).toISOString().slice(0,10), e: new Date(r.checkOut).toISOString().slice(0,10) }))) %>;

  var today = new Date().toISOString().slice(0, 10);
  cin.min  = today;
  cout.min = today;

  function toDate(str) { var p = str.split('-'); return new Date(p[0], p[1]-1, p[2]); }

  function hasConflict(cInStr, cOutStr) {
    var a = toDate(cInStr), b = toDate(cOutStr);
    return bookedRanges.some(function(r) {
      return a < toDate(r.e) && b > toDate(r.s);
    });
  }

  function fmt(n) { return '₹' + n.toLocaleString('en-IN'); }

  function updateUI() {
    var cInVal = cin.value, cOutVal = cout.value;
    var btn    = document.getElementById('reserveBtn');
    var sumDiv = document.getElementById('priceSummary');
    var conf   = document.getElementById('bookingConflict');

    if (!cInVal || !cOutVal) {
      btn.disabled = true; btn.textContent = 'Select dates to reserve';
      sumDiv.style.display = 'none'; conf.style.display = 'none';
      return;
    }
    if (toDate(cOutVal) <= toDate(cInVal)) {
      btn.disabled = true; conf.style.display = 'flex';
      document.getElementById('conflictMsg').textContent = 'Check-out must be after check-in.';
      sumDiv.style.display = 'none'; return;
    }
    if (hasConflict(cInVal, cOutVal)) {
      btn.disabled = true; conf.style.display = 'flex';
      document.getElementById('conflictMsg').textContent = 'These dates overlap with an existing booking.';
      sumDiv.style.display = 'none'; return;
    }
    conf.style.display = 'none';
    var nights = Math.ceil((toDate(cOutVal) - toDate(cInVal)) / 86400000);
    var total  = nights * pricePerNight;
    document.getElementById('nightsLabel').textContent = nights + ' night' + (nights > 1 ? 's' : '') + ' × ' + fmt(pricePerNight);
    document.getElementById('nightsTotal').textContent = fmt(total);
    document.getElementById('grandTotal').textContent  = fmt(total);
    sumDiv.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Reserve';
  }

  cin.addEventListener('change', function() {
    if (cout.value && cout.value <= cin.value) cout.value = '';
    var nextDay = new Date(toDate(cin.value));
    nextDay.setDate(nextDay.getDate() + 1);
    cout.min = nextDay.toISOString().slice(0, 10);
    updateUI();
  });
  cout.addEventListener('change', updateUI);
})();
</script>

<!-- Reviews Section (full width below grid) -->
<div class="reviews-section">
  <% if(listing.reviews.length > 0) { %>
    <h3 class="reviews-heading">
      <i class="fa-solid fa-star me-2" style="color: var(--coral);"></i>
      <%= listing.reviews.length %> Review<%= listing.reviews.length !== 1 ? 's' : '' %>
    </h3>

    <% for(let review of listing.reviews) { %>
      <div class="review-card">
        <div class="review-author">@<%= review.author.username %></div>
        <div class="review-date">
          <%= new Date(review.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </div>
        <p class="starability-result" data-rating="<%= review.rating %>"></p>
        <p class="review-comment"><%= review.comment %></p>
        <% if(currUser && currUser._id.equals(review.author._id)) { %>
          <div class="review-actions">
            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button type="submit" class="btn-danger-ghost">
                <i class="fa-solid fa-trash me-1"></i> Delete
              </button>
            </form>
          </div>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <div class="reviews-heading">
      <p style="color: var(--text-secondary); font-size: 0.9rem; font-weight: 400; padding-top: 1rem;">No reviews yet. Be the first!</p>
    </div>
  <% } %>
</div>
</div>

